#include <iostream>
#include <vector>
using namespace std;

bool isPrime(int num) {
    if (num < 2)
        return false;

    for (int i = 2; i * i <= num; i++) {
        if (num % i == 0)
            return false;
    }

    return true;
}

vector<int> sieve(int n) {
    vector<int> res;

    for (int i = 2; i <= n; i++) {
        if (isPrime(i)) {
            res.push_back(i);
        }
    }

    return res;
}

int main() {
    int n = 35;

    vector<int> res = sieve(n);

    for (auto ele : res) {
        cout << ele << ' ';
    }

    return 0;
}
