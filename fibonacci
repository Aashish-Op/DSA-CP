#include <bits/stdc++.h>
using namespace std;

int fib(int n) {
    if (n <= 1) return n;   // base cases: F(0)=0, F(1)=1
    int prev2 = 0, prev1 = 1;  // store F(n-2) and F(n-1)
    for (int i = 2; i <= n; i++) {
        int curr = prev1 + prev2;  // F(n) = F(n-1) + F(n-2)
        prev2 = prev1;             // shift values
        prev1 = curr;
    }
    return prev1;  // final answer
}

int main() {
    int n;
    cin >> n;
    cout << fib(n) << endl;
    return 0;
}
