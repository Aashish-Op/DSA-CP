#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> relativeSortArray(vector<int>& arr1, vector<int>& arr2) {
        const int MAXV = 1000;
        vector<int> freq(MAXV + 1, 0);
        for (int x : arr1) freq[x]++;

        vector<int> res;
        res.reserve(arr1.size());

        for (int x : arr2) {
            while (freq[x]-- > 0) res.push_back(x);
        }

        for (int v = 0; v <= MAXV; ++v) {
            while (freq[v]-- > 0) res.push_back(v);
        }

        return res;
    }
};

int main() {
    Solution s;
    vector<int> arr1 = {2,3,1,3,2,4,6,7,9,2,19};
    vector<int> arr2 = {2,1,4,3,9,6};
    vector<int> ans = s.relativeSortArray(arr1, arr2);
    for (int x : ans) cout << x << " ";
    cout << "\n";
    return 0;
}
