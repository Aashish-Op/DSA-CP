#include <vector>

int recursiveSearch(const std::vector<int>& arr, int low, int high, int target) {
    if (low > high) return -1;

    int mid = low + (high - low) / 2;

    if (arr[mid] == target) return mid;
    if (target < arr[mid]) return recursiveSearch(arr, low, mid - 1, target);
    return recursiveSearch(arr, mid + 1, high, target);
}

